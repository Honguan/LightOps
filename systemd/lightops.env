LIGHTOPS_DATA_DIR=/var/lib/lightops
LIGHTOPS_LOG_DIR=/var/log/lightops
LIGHTOPS_BACKUP_DIR=/var/backups/lightops
LIGHTOPS_MANIFESTS_DIR=/opt/lightops/current/manifests
LIGHTOPS_PRIVILEGED_HELPER=/opt/lightops/current/venv/bin/lightops-privileged
LIGHTOPS_SECRET_KEY_FILE=/etc/lightops/secret.key
# LIGHTOPS_IP_ALLOWLIST=127.0.0.1,192.0.2.10
# LIGHTOPS_CUSTOM_SERVICES=my-app.service,worker@1.service
AUTO_UPDATE=false
UPDATE_CHANNEL=stable
LIGHTOPS_REPORT_HOUR=1
# LIGHTOPS_BACKUP_SOURCES=/var/www,/etc/nginx
LIGHTOPS_BACKUP_RETENTION=7
# LIGHTOPS_DATABASE_URL=postgresql+psycopg://lightops@127.0.0.1/lightops
# LIGHTOPS_WEBHOOK_URL=https://example.invalid/lightops-alerts
